# Server Configuration
PAYMENT_API_HOST=127.0.0.1
PAYMENT_API_PORT=3002

# Database
# Neon pooled connection string (recommended)
# Format from Neon docs:
# postgresql://USER:PASSWORD@EP-ENDPOINT-pooler.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require
PAYMENT_DATABASE_URL=postgresql://user:pass@ep-example-123456-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require
PAYMENT_REQUIRE_NEON=true

# LemonSqueezy API
LEMONSQUEEZY_API_KEY=lsq_test_your_api_key_here
LEMONSQUEEZY_STORE_ID=your_store_id
LEMONSQUEEZY_WEBHOOK_SECRET=12345678

# Product Variants (canonical one-time licenses)
LEMONSQUEEZY_VARIANT_ID_BASIC=12345
LEMONSQUEEZY_VARIANT_ID_PRO=12346

# Backward compatibility variants (optional)
LEMONSQUEEZY_VARIANT_ID_BASIC_MONTHLY=12345
LEMONSQUEEZY_VARIANT_ID_BASIC_ANNUAL=12346
LEMONSQUEEZY_VARIANT_ID_PRO_MONTHLY=12347
LEMONSQUEEZY_VARIANT_ID_PRO_ANNUAL=12348

# JWT (shared with auth-server for token validation)
JWT_SECRET=your_shared_jwt_secret

# Environment
IS_PRODUCTION=false
LEMONSQUEEZY_TEST_MODE=true

# Comma-separated CORS origins (used when IS_PRODUCTION=true)
PAYMENT_ALLOWED_ORIGINS=http://localhost:1420,http://127.0.0.1:1420,tauri://localhost
