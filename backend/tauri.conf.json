{
  "productName": "Trueears",
  "version": "0.3.2",
  "identifier": "com.Trueears",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run vite:dev",
    "beforeBuildCommand": "npm run vite:build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Trueears",
        "width": 3840,
        "height": 2160,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": false,
        "resizable": false,
        "fullscreen": false,
        "focus": false,
        "x": 0,
        "y": 0
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; media-src 'self' blob: mediastream:; connect-src 'self' https://api.groq.com https://*.vercel.app http://localhost:* http://127.0.0.1:*",
      "capabilities": [
        "main-window",
        "settings-window"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "deb",
      "appimage"
    ],
    "licenseFile": "./assets/legal/terms-and-privacy.txt",
    "icon": [
      "../build/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "../build/icon.ico",
        "installMode": "currentUser"
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  },
  "plugins": {
    "globalShortcut": {
      "shortcuts": []
    }
  }
}
